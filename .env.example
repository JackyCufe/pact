# ── Agent Identity ─────────────────────────────────────────────────────────────
ATA_AGENT_ID=agent://yourname/main
ATA_AGENT_NAME=My ATA Agent
ATA_AGENT_OWNER=yourname
ATA_PORT=3740
ATA_PUBLIC_URL=http://localhost:3740

# ── Security ────────────────────────────────────────────────────────────────────
# Shared secret for HMAC-SHA256 signing. Exchange this with your peer.
ATA_SHARED_SECRET=change-this-to-a-random-secret

# ── Capabilities ────────────────────────────────────────────────────────────────
ATA_CAPABILITIES=ping,echo,ask_agent

# ── LLM Backend ─────────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint: LiteLLM, Ollama, OpenAI, etc.

# LiteLLM (local proxy — recommended)
ATA_LLM_BASE_URL=http://localhost:4000/v1
ATA_LLM_API_KEY=no-key
ATA_LLM_MODEL=claude-sonnet-4-6

# Ollama (local, free)
# ATA_LLM_BASE_URL=http://localhost:11434/v1
# ATA_LLM_API_KEY=ollama
# ATA_LLM_MODEL=llama3

# OpenAI
# ATA_LLM_BASE_URL=https://api.openai.com/v1
# ATA_LLM_API_KEY=sk-...
# ATA_LLM_MODEL=gpt-4o
